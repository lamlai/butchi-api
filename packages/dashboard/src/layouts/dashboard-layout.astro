---
import "../styles/tokens.css";
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - Butchi</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: var(--font-family);
        background: var(--color-canvas);
        color: var(--color-ink);
        min-height: 100vh;
        display: flex;
      }
      .sidebar {
        width: 240px;
        background: var(--color-inverse-canvas);
        color: var(--color-inverse-ink);
        padding: var(--space-lg);
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
      }
      .sidebar h2 {
        font-weight: var(--font-weight-light);
        font-size: 24px;
        margin-bottom: var(--space-xl);
        color: var(--color-inverse-ink);
      }
      .sidebar a {
        color: var(--color-inverse-ink-muted);
        text-decoration: none;
        padding: var(--space-xs) var(--space-sm);
        font-size: 14px;
        letter-spacing: 0.16px;
        border-radius: var(--radius-none);
        transition: background 0.15s;
      }
      .sidebar a:hover,
      .sidebar a.active {
        background: var(--color-inverse-surface-1, #262626);
        color: var(--color-inverse-ink);
      }
      .admin-nav {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
      }
      .main {
        flex: 1;
        padding: var(--space-xxl);
        max-width: 960px;
      }
      .main h1 {
        font-weight: var(--font-weight-light);
        font-size: 42px;
        line-height: 1.2;
        margin-bottom: var(--space-xl);
      }
    </style>
  </head>
  <body>
    <nav class="sidebar">
      <h2>Butchi</h2>
      <a href="/dashboard/usage">Usage</a>
      <a href="/dashboard/billing">Billing</a>
      <a href="/dashboard/api-keys">API Keys</a>
      <a href="/dashboard/profile">Profile</a>
      <div class="admin-nav" id="admin-nav" style="display:none;">
        <hr style="border-color: var(--color-inverse-surface-1, #262626); margin: var(--space-sm) 0;" />
        <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.32px; color: var(--color-inverse-ink-muted); padding: var(--space-xs) var(--space-sm);">Admin</span>
        <a href="/dashboard/admin/users">Users</a>
        <a href="/dashboard/admin/transactions">Transactions</a>
      </div>
      <div style="margin-top: auto; padding-top: var(--space-lg);">
        <hr style="border-color: var(--color-inverse-surface-1, #262626); margin-bottom: var(--space-sm);" />
        <a href="#" id="logout-btn" style="color: var(--color-inverse-ink-muted); cursor: pointer;">Logout</a>
      </div>
    </nav>
    <main class="main">
      <h1>{title}</h1>
      <slot />
    </main>
    <script>
      function getTokenPayload() {
        try {
          const match = document.cookie.match(/(?:^|; )token=([^;]+)/);
          if (!match) return null;
          const base64 = match[1].split('.')[1];
          const json = atob(base64.replace(/-/g, '+').replace(/_/g, '/'));
          return JSON.parse(json);
        } catch { return null; }
      }

      const payload = getTokenPayload();
      if (payload?.role === 'admin') {
        const adminNav = document.getElementById('admin-nav');
        if (adminNav) adminNav.style.display = 'flex';
      }

      document.getElementById('logout-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        document.cookie = 'token=; path=/; max-age=0';
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
