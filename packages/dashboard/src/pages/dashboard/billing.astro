---
import DashboardLayout from "../../layouts/dashboard-layout.astro";
---

<DashboardLayout title="Billing">
  <div id="billing-root">
    <section style="margin-bottom: var(--space-xl);">
      <h2 style="font-weight: var(--font-weight-regular); font-size: 20px; margin-bottom: var(--space-md);">Current Balance</h2>
      <p id="balance" style="font-size: 32px; font-weight: var(--font-weight-light); color: var(--color-primary);">Loading...</p>
    </section>
    <section>
      <h2 style="font-weight: var(--font-weight-regular); font-size: 20px; margin-bottom: var(--space-md);">Top Up</h2>
      <div style="display: flex; gap: var(--space-sm); align-items: end;">
        <div>
          <label style="display: block; font-size: 14px; margin-bottom: var(--space-xxs); color: var(--color-ink-muted);">Amount (VND)</label>
          <input id="topup-amount" type="number" value="50000" min="10000" step="10000"
            style="background: var(--color-surface-1); border: none; border-bottom: 1px solid var(--color-hairline); padding: 11px 16px; font-family: var(--font-family); font-size: 16px; width: 200px;" />
        </div>
        <button id="topup-btn"
          style="background: var(--color-primary); color: var(--color-on-primary); border: none; padding: 12px 16px; font-family: var(--font-family); font-size: 14px; cursor: pointer;">
          Generate QR
        </button>
      </div>
    </section>
    <div id="topup-qr" style="margin-top: var(--space-lg); display: none;">
      <img id="qr-image" style="width: 256px; height: 256px; border: 1px solid var(--color-hairline);" />
    </div>
  </div>
  <script>
    async function loadBilling() {
      try {
        const res = await fetch("/api/billing", {
          headers: { Authorization: `Bearer ${getToken()}` },
        });
        const data = await res.json();
        document.getElementById("balance")!.textContent =
          `${(data.balance_cents / 100).toLocaleString("vi-VN")} VND`;
      } catch {
        document.getElementById("balance")!.textContent = "Error loading balance";
      }
    }
    function getToken() {
      const match = document.cookie.match(new RegExp(`(^| )token=([^;]+)`));
      return match ? decodeURIComponent(match[2]) : "";
    }
    document.getElementById("topup-btn")!.addEventListener("click", async () => {
      const amount = (document.getElementById("topup-amount") as HTMLInputElement).value;
      try {
        const res = await fetch("/api/billing/topup", {
          method: "POST",
          headers: { "Content-Type": "application/json", Authorization: `Bearer ${getToken()}` },
          body: JSON.stringify({ amount_vnd: parseInt(amount) }),
        });
        const data = await res.json();
        const qrDiv = document.getElementById("topup-qr")!;
        const qrImg = document.getElementById("qr-image") as HTMLImageElement;
        if (data.qrUrl) {
          qrImg.src = data.qrUrl;
          qrDiv.style.display = "block";
        }
      } catch (err) {
        alert("Failed to create top-up");
      }
    });
    loadBilling();
  </script>
</DashboardLayout>
